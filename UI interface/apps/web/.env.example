# Copy to .env. Do not commit .env.
# Required: Worker URL (use your deployed Worker URL).
VITE_API_URL=https://job-tracker-api.katishay.workers.dev
# Optional: only needed if you set API_SHARED_TOKEN on the Worker (npx wrangler secret put API_SHARED_TOKEN).
# Use the exact same value here. If the Worker has no token set, the API is open and this can be left empty.
VITE_API_TOKEN=
